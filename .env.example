NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_VERSION=
BUILD_TIME=
GIT_COMMIT=

# MySQL connection string
DATABASE_URL=mysql://root:password@127.0.0.1:3306/selrs_db

# Authentication
JWT_SECRET=change-me-in-production

# Optional app settings
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: MSSQL patient sync (source of truth from accounting system)
MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_AUTH_MODE=sql
# For Windows auth mode, install msnodesqlv8 and set this full ODBC connection string:
# MSSQL_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=192.168.0.100,1433;Database=op2026;Trusted_Connection=Yes;TrustServerCertificate=Yes;
MSSQL_CONNECTION_STRING=
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
# Optional custom query. If empty, defaults to selecting standard patient columns from Patients table.
MSSQL_PATIENTS_QUERY=
MSSQL_SYNC_LIMIT=5000
# Auto sync every interval (milliseconds)
MSSQL_SYNC_AUTO=false
MSSQL_SYNC_INTERVAL_MS=300000
MSSQL_SYNC_INCREMENTAL_AUTO=true
MSSQL_SYNC_UPDATE_EXISTING=false
MSSQL_SYNC_PRESERVE_MANUAL_EDITS=true
MSSQL_SYNC_LINK_SERVICES_FOR_EXISTING=true
MSSQL_PUSH_CREATE_SERVICE_ROW=false
MSSQL_PUSH_DEDUP_SECONDS=90
# Optional doctor-code CSV mapping (default: ./MD.csv with CODE;PHNM_AR)
MSSQL_DOCTOR_MAP_CSV=

# Optional: Black Ice folder -> MySQL importer (for builds where ODBC upload SQL is incompatible)
# Defaults to ./Pentacam if not set.
BLACKICE_IMPORT_ENABLED=true
BLACKICE_IMPORT_SOURCE_DIR=E:/Web.selrs.cc/Pentacam/incoming
BLACKICE_IMPORT_PROCESSED_DIR=
BLACKICE_IMPORT_FAILED_DIR=
BLACKICE_IMPORT_SOURCE_PRINTER=Pentacam
BLACKICE_IMPORT_POLL_MS=10000
BLACKICE_IMPORT_MIN_FILE_AGE_MS=5000
BLACKICE_IMPORT_MAX_FILES_PER_CYCLE=20

# Optional: OCR + auto-link uploads to patients by extracted numeric IDs
BLACKICE_OCR_ENABLED=false
BLACKICE_OCR_POLL_MS=20000
BLACKICE_OCR_BATCH_SIZE=10
BLACKICE_OCR_TESSERACT_PATH=tesseract
BLACKICE_OCR_LANG=eng
BLACKICE_OCR_PSM=6
